PORT=4000
DATABASE_URL=postgresql://user:password@localhost:5432/veganfit

# JWT for REST auth
JWT_SECRET=replace-with-long-random-secret-at-least-32-chars

# Google login (optional)
GOOGLE_CLIENT_ID=replace-with-google-client-id.apps.googleusercontent.com

# Email OTP (SMTP / Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
AUTH_FROM_EMAIL=noreply@veganfit.app

# CORS origins
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# Internal secret (Next.js webhook → backend order creation)
INTERNAL_SECRET=replace-with-shared-secret-32-chars

# Cloudinary (signed uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# AI (optional, unused — kept for reference)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# AI Assistant — Anthropic Claude API (required for /ai-assistant/chat to work)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-5