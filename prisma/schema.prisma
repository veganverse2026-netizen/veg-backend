generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Goal {
  FAT_LOSS
  MUSCLE_BUILD
  LIFESTYLE
}

enum ActivityLevel {
  SEDENTARY
  LIGHT
  MODERATE
  ACTIVE
  ATHLETE
}

enum Gender {
  FEMALE
  MALE
  OTHER
}

enum RecipeCategory {
  FAT_LOSS
  MUSCLE_BUILD
  LIFESTYLE
}

enum WorkoutType {
  HOME
  GYM
}

enum OtpPurpose {
  SIGNUP
  LOGIN
  RESET
}

enum PostType {
  QUESTION
  WIN
  MEAL_IDEA
  NEED_SUPPORT
}

enum UserRole {
  MEMBER
  GYM_TRAINER
  ADMIN
}

enum PlanChangeStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model User {
  id                     String         @id @default(cuid())
  name                   String?
  email                  String?        @unique
  emailVerified          DateTime?
  image                  String?
  passwordHash           String?
  heightCm               Float?
  weightKg               Float?
  bodyFatPercent         Float?
  age                    Int?
  gender                 Gender?
  activityLevel          ActivityLevel?
  goal                   Goal?
  dietaryStyle           String?
  dietaryPreferences     String[]       @default([])
  calorieTargetOverride  Int?
  proteinTargetOverride  Int?
  hydrationTargetOverride Float?
  goalLocked             Boolean        @default(false)
  onboardingDone         Boolean        @default(false)
  onboardingCompletedAt  DateTime?
  streakCount            Int            @default(0)
  role                   UserRole       @default(MEMBER)
  gymTrainerId           String?
  approvedGymPlanJson    String?        @db.Text
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  accounts               Account[]
  sessions               Session[]
  trackers               Tracker[]
  workoutLogs            WorkoutLog[]
  streaks                Streak[]
  cheatMeals             CheatMeal[]
  posts                  Post[]
  comments               Comment[]
  savedRecipes           SavedRecipe[]
  likes                  PostLike[]
  postBookmarks          PostBookmark[]
  commentLikes           CommentLike[]
  challengesCreated      Challenge[]
  challengeParticipation ChallengeParticipant[]
  challengeCheckIns      ChallengeCheckIn[]
  following              Follow[]       @relation("Following")
  followers              Follow[]       @relation("Followers")
  dmConversationsA       Conversation[] @relation("ConversationUserA")
  dmConversationsB       Conversation[] @relation("ConversationUserB")
  dmMessages             Message[]
  dmReads                ConversationRead[]
  gymTrainer             GymTrainer?    @relation("AssignedTrainer", fields: [gymTrainerId], references: [id], onDelete: SetNull)
  trainerProfile         GymTrainer?    @relation("TrainerLinkedAccount")
  workoutPlanRequests    WorkoutPlanChangeRequest[] @relation("MemberPlanRequests")
  reviewedPlanRequests   WorkoutPlanChangeRequest[] @relation("PlanReviewedBy")
  gymProgressPhotos      GymProgressPhoto[]
  missedWorkoutReports   MissedWorkoutReport[]
  orders                 Order[]
  addresses              Address[]
  reviews                Review[]
  notifications          Notification[]
  reportsMade            Report[]       @relation("ReportsMade")
}

model GymTrainer {
  id               String   @id @default(cuid())
  name             String
  title            String?
  bio              String?
  imageUrl         String?
  sortOrder        Int      @default(0)
  certifications   String?
  specializations  String[] @default([])
  yearsExperience  Int?
  workingHours     String?
  languages        String[] @default([])
  contactEmail     String?
  contactPhone     String?
  active           Boolean  @default(true)
  approved         Boolean  @default(false)
  maxUsers         Int?
  linkedUserId     String?  @unique
  linkedUser     User?    @relation("TrainerLinkedAccount", fields: [linkedUserId], references: [id], onDelete: SetNull)
  assignedUsers  User[]   @relation("AssignedTrainer")
  planRequests   WorkoutPlanChangeRequest[]
  missedWorkoutReports MissedWorkoutReport[]

  @@index([sortOrder])
}

model GymProgressPhoto {
  id        String   @id @default(cuid())
  userId    String
  imageUrl  String
  caption   String?  @db.Text
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model MissedWorkoutReport {
  id             String   @id @default(cuid())
  userId         String
  gymTrainerId   String
  reason         String   @db.Text
  createdAt      DateTime @default(now())

  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  gymTrainer     GymTrainer @relation(fields: [gymTrainerId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([gymTrainerId, createdAt])
}

model WorkoutPlanChangeRequest {
  id                   String           @id @default(cuid())
  userId               String
  gymTrainerId         String
  status               PlanChangeStatus @default(PENDING)
  memberNote           String?
  proposedSessionsJson String           @db.Text
  trainerComment       String?
  reviewedAt           DateTime?
  reviewedByUserId     String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  user         User       @relation("MemberPlanRequests", fields: [userId], references: [id], onDelete: Cascade)
  gymTrainer   GymTrainer @relation(fields: [gymTrainerId], references: [id], onDelete: Cascade)
  reviewedBy   User?      @relation("PlanReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([gymTrainerId, status])
}

model OtpChallenge {
  id           String      @id @default(cuid())
  email        String
  purpose      OtpPurpose
  codeHash     String
  name         String?
  passwordHash String?
  attempts     Int         @default(0)
  consumedAt   DateTime?
  expiresAt    DateTime
  createdAt    DateTime    @default(now())

  @@index([email, purpose, expiresAt])
}

model Recipe {
  id               String         @id @default(cuid())
  name             String
  image            String
  category         RecipeCategory
  description      String
  ingredients      String[]
  steps            String[]
  calories         Int
  protein          Int
  carbs            Int
  fats             Int
  isCheatMeal      Boolean        @default(false)
  createdAt        DateTime       @default(now())

  savedBy          SavedRecipe[]
  cheatSelections  CheatMeal[]
}

model Tracker {
  id               String    @id @default(cuid())
  userId           String
  date             DateTime  @default(now())
  weightKg         Float?
  caloriesConsumed Int?
  proteinIntake    Int?
  workoutCompleted Boolean   @default(false)

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model Streak {
  id         String    @id @default(cuid())
  userId     String
  date       DateTime
  completed  Boolean   @default(false)

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model CheatMeal {
  id         String    @id @default(cuid())
  userId     String
  recipeId   String
  weekStart  DateTime
  selectedAt DateTime  @default(now())
  expiresAt  DateTime
  consumed   Boolean   @default(false)

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe     Recipe    @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([userId, weekStart])
}

model Post {
  id        String    @id @default(cuid())
  userId    String
  content   String
  recipeLink String?
  type      PostType  @default(QUESTION)
  imageUrl  String?
  acceptedCommentId String?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments  Comment[]
  likes     PostLike[]
  bookmarks PostBookmark[]
  reports   Report[]
}

model Comment {
  id        String    @id @default(cuid())
  userId    String
  postId    String
  parentId  String?
  content   String
  createdAt DateTime  @default(now())

  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post        @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent    Comment?    @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[]   @relation("CommentReplies")
  likes     CommentLike[]

  @@index([postId, parentId])
}

model CommentLike {
  id        String   @id @default(cuid())
  userId    String
  commentId String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
}

model SavedRecipe {
  id        String    @id @default(cuid())
  userId    String
  recipeId  String
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe    Recipe    @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([userId, recipeId])
}

model PostLike {
  id        String    @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model PostBookmark {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower    User     @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

model Conversation {
  id        String   @id @default(cuid())
  userAId   String
  userBId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userA     User     @relation("ConversationUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB     User     @relation("ConversationUserB", fields: [userBId], references: [id], onDelete: Cascade)
  messages  Message[]
  reads     ConversationRead[]

  @@unique([userAId, userBId])
  @@index([userAId, updatedAt])
  @@index([userBId, updatedAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  createdAt      DateTime     @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId, createdAt])
}

model ConversationRead {
  id             String       @id @default(cuid())
  conversationId String
  userId         String
  lastReadAt     DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId, updatedAt])
}

model Workout {
  id          String     @id @default(cuid())
  title       String
  description String
  type        WorkoutType
  goal        Goal
  durationMin Int
  level       String
  imageUrl    String?
  rating      Float?
}

model WorkoutLog {
  id          String    @id @default(cuid())
  userId      String
  performedAt DateTime  @default(now())
  exercise    String
  sets        Int
  reps        Int
  weightKg    Float
  notes       String?
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, performedAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── E-Commerce ────────────────────────────────────────────────────────────────

model ProductCategory {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  imageUrl    String?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())

  products    Product[]

  @@index([slug])
}

model Product {
  id          String        @id @default(cuid())
  categoryId  String
  name        String
  slug        String        @unique
  description String        @db.Text
  price       Float
  comparePrice Float?
  imageUrls   String[]
  tags        String[]
  status      ProductStatus @default(DRAFT)
  stock       Int           @default(0)
  weight      Float?
  isVegan     Boolean       @default(true)
  isFeatured  Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  category    ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  orderItems  OrderItem[]
  reviews     Review[]

  @@index([categoryId, status])
  @@index([status, isFeatured])
  @@index([slug])
}

model Address {
  id         String   @id @default(cuid())
  userId     String
  name       String
  line1      String
  line2      String?
  city       String
  state      String
  pincode    String
  country    String   @default("IN")
  phone      String?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders     Order[]

  @@index([userId])
}

model Order {
  id              String      @id @default(cuid())
  userId          String
  addressId       String?
  status          OrderStatus @default(PENDING)
  stripeSessionId String?     @unique
  stripePaymentId String?
  subtotal        Float
  tax             Float       @default(0)
  shipping        Float       @default(0)
  total           Float
  notes           String?     @db.Text
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  address     Address?    @relation(fields: [addressId], references: [id], onDelete: SetNull)
  items       OrderItem[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([stripeSessionId])
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  productId  String
  quantity   Int
  unitPrice  Float
  total      Float
  productSnap Json

  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  productId String
  rating    Int
  title     String?
  body      String?  @db.Text
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId, rating])
}

// ─── Notifications ──────────────────────────────────────────────────────────

enum NotificationType {
  ORDER_UPDATE
  COMMUNITY
  GYM
  MEAL
  SYSTEM
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType @default(SYSTEM)
  title     String
  body      String
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
}

// ─── Community Reports ──────────────────────────────────────────────────────

enum ReportStatus {
  PENDING
  RESOLVED
  DISMISSED
}

model Report {
  id          String       @id @default(cuid())
  reporterId  String
  postId      String
  reason      String
  status      ReportStatus @default(PENDING)
  resolvedAt  DateTime?
  resolvedBy  String?
  createdAt   DateTime     @default(now())

  reporter    User         @relation("ReportsMade", fields: [reporterId], references: [id], onDelete: Cascade)
  post        Post         @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, status])
  @@index([reporterId])
}

model JourneyProgress {
  id        String   @id @default(cuid())
  key       String   @unique
  step      Int      @default(0)
  updatedAt DateTime @updatedAt
}

enum ChallengeCategory {
  MEAL
  WORKOUT
  STEPS
  WATER
  MEDITATION
  RECIPE
  GYM_PROGRESS
  CUSTOM
}

enum ChallengeDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

model Challenge {
  id            String              @id @default(cuid())
  title         String
  description   String              @db.Text
  category      ChallengeCategory   @default(CUSTOM)
  difficulty    ChallengeDifficulty @default(BEGINNER)
  coverImageUrl String?
  rules         String?             @db.Text
  rewardText    String?             @db.Text
  durationDays  Int
  startDate     DateTime            @default(now())
  endDate       DateTime
  createdById   String
  createdAt     DateTime            @default(now())

  createdBy    User                   @relation(fields: [createdById], references: [id], onDelete: Cascade)
  participants ChallengeParticipant[]
  checkIns     ChallengeCheckIn[]

  @@index([endDate])
}

model ChallengeParticipant {
  id          String   @id @default(cuid())
  challengeId String
  userId      String
  joinedAt    DateTime @default(now())

  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([challengeId, userId])
}

model ChallengeCheckIn {
  id          String   @id @default(cuid())
  challengeId String
  userId      String
  date        DateTime
  createdAt   DateTime @default(now())

  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([challengeId, userId, date])
}

